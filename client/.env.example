# ═══════════════════════════════════════════════════════
# CONFIGURAÇÕES DO FIREBASE (CERVEJARIA ARTESANAL)
# ═══════════════════════════════════════════════════════
#
# Instruções:
# 1. Duplique este arquivo na raiz do projeto e renomeie a cópia para `.env`
# 2. Crie um projeto no Firebase Console (https://console.firebase.google.com)
# 3. Adicione um App Web no Firebase para obter estas chaves públicas
# 4. Substitua os valores abaixo com as credenciais do seu projeto Firebase

VITE_FIREBASE_API_KEY=sua_api_key_aqui
VITE_FIREBASE_AUTH_DOMAIN=seu_projeto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=seu_projeto_id
VITE_FIREBASE_STORAGE_BUCKET=seu_projeto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=seu_messaging_sender_id_aqui
VITE_FIREBASE_APP_ID=1:seu_app_id_aqui
